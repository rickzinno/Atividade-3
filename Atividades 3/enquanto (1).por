programa
{
	funcao inicio()
	{			  
		inteiro numero
		escreva("Qual numero voce escolhe? de 1 a 4:")
		leia(numero)
		escolha(numero)
	{
		caso 1:
		escreva("Flamengo")
		pare
		caso 2:
		escreva("Vasco")
pare
		caso 3:
		escreva("Palmeiras")
	pare	
		caso 4:
		escreva("Bota fogo")
	pare
		caso contrario:
		escreva("é de 1 a 4 burro!!")
	}
	}
}
